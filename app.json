{
  "expo": {
    "name": "HLS Player",
    "slug": "hls-tv-player",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "scheme": "hlsplayer",
    "extra": {
      "eas": {
        "projectId": "8d2cc8de-01f7-490c-98e0-707709cbdb79"
      }
    },
    "android": {
      "package": "com.hlsplayer.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "android.intent.action.MAIN",
          "category": [
            "android.intent.category.LAUNCHER"
          ]
        },
        {
          "action": "android.intent.action.MAIN",
          "category": [
            "android.intent.category.LEANBACK_LAUNCHER"
          ]
        }
      ]
    },
    "plugins": [
      [
        "react-native-video",
        {
          "enableNotificationControls": false
        }
      ]
    ]
  }
}
