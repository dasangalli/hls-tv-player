{
  "expo": {
    "name": "HLS TV Player",
    "slug": "hls-tv-player",
    "version": "1.0.0",
    "orientation": "landscape",
    "userInterfaceStyle": "dark",
    "scheme": "hlstvplayer",
    "android": {
      "package": "com.hlstvplayer.app",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "android.intent.action.MAIN",
          "category": [
            "android.intent.category.LEANBACK_LAUNCHER"
          ]
        }
      ]
    },
    "plugins": [
      [
        "react-native-video",
        {
          "enableNotificationControls": false
        }
      ]
    ]
  }
}
